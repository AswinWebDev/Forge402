# AgentHub Configuration
# Copy this to .env and fill in your values

# Venice AI (for orchestration)
VENICE_API_KEY=your_venice_api_key

# GitHub API Token (for github-auditor service)
GITHUB_TOKEN=your_github_token

# Platform Wallet (pays for x402 tools — keep secret!)
STELLAR_CLIENT_SECRET=your_stellar_secret
STELLAR_CLIENT_PUBLIC=your_stellar_public

# Tool Provider Wallet (receives x402 payments)
STELLAR_PROVIDER_SECRET=your_provider_secret
STELLAR_PROVIDER_PUBLIC=your_provider_public

# x402 Network
STELLAR_NETWORK=stellar:testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
X402_FACILITATOR_URL=https://www.x402.org/facilitator

# Platform Settings
ADMIN_KEY=change_this_to_a_strong_key
PORT=4000

# For local dev: http://localhost
# For production: your deployed URL (e.g., https://agenthub-api.onrender.com)
BASE_URL=http://localhost
REGISTRY_URL=http://localhost:4000
